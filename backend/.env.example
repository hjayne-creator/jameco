# Required: at least one LLM provider key
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Required for competitor + manufacturer discovery
SERPAPI_API_KEY=

# Required for primary scraping
FIRECRAWL_API_KEY=
# Optional: delay Firecrawl scrape to allow JS rendering (milliseconds)
FIRECRAWL_WAIT_FOR_MS=

# Optional fallback browser for blocked / JS-heavy pages
BROWSERBASE_API_KEY=
BROWSERBASE_PROJECT_ID=

# App config
DATABASE_URL=sqlite:///./jameco.db
APP_HOST=0.0.0.0
APP_PORT=8000
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Default models per role (swappable per step in workflow/prompts/registry.py)
LLM_REASONING_MODEL=claude-sonnet-4-6
LLM_WRITING_MODEL=claude-sonnet-4-6
LLM_EXTRACTION_MODEL=gpt-5
